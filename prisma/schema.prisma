generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  password      String?
  role          Role      @default(SELLER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  properties    Property[]
  agency        Agency?   @relation(fields: [agencyId], references: [id])
  agencyId      String?
  sessions      Session[]
  accounts      Account[]
  sentMessages      Message[] @relation("SentMessages")
  receivedMessages  Message[] @relation("ReceivedMessages")
  uploadedDocuments Document[] @relation("UploadedDocuments")
  favorites         Favorite[]
  savedSearches     SavedSearch[]
  reviews           Review[]
  // Consent tracking
  termsAcceptedAt    DateTime?
  privacyAcceptedAt  DateTime?
  fase2ConsentAt     DateTime?
  clausoleApprovedAt DateTime?
  marketingConsent   Boolean   @default(false)
  termsVersion       String?
  termsAcceptedIp    String?
}

enum Role {
  SELLER
  BUYER
  AGENCY_ADMIN
  AGENCY_AGENT
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Agency {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  phone            String
  address          String
  city             String
  province         String
  lat              Float?
  lng              Float?
  coverageRadius   Int?
  plan             AgencyPlan @default(BASE)
  isActive         Boolean   @default(false)
  stripeCustomerId String?
  stripeSubId      String?
  logoUrl          String?
  description      String?   @db.Text
  rating           Float?    @default(0)
  reviewCount      Int       @default(0)
  // Fatturazione elettronica
  ragioneSociale   String?
  partitaIva       String?
  codiceFiscale    String?
  pec              String?
  codiceSdi        String?   @default("0000000")
  invoiceAddress   String?
  invoiceCity      String?
  invoiceProvince  String?
  invoiceCap       String?
  // Accettazione contratto di convenzionamento
  contractAcceptedAt       DateTime?
  privacyAcceptedAt        DateTime?
  zeroCommissionAcceptedAt DateTime?
  clausoleAcceptedAt       DateTime?
  registroAcceptedAt       DateTime?
  contractVersion          String?
  contractAcceptedIp       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  agents           User[]
  assignments      PropertyAssignment[]
  reviews          Review[]
  territories      TerritoryAssignment[]
}

enum AgencyPlan {
  BASE
  PREMIER_LOCAL
  PREMIER_CITY
  PREMIER_PRIME
  PREMIER_ELITE
}

enum ZoneClass {
  CLUSTER_LOCAL
  COMUNE
  MACROQUARTIERE
  MICROZONA_PRIME
}

model Property {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  description   String?        @db.Text
  type          PropertyType
  status        PropertyStatus @default(DRAFT)
  price         Int
  surface       Int
  rooms         Int
  bathrooms     Int?
  floor         Int?
  totalFloors   Int?
  hasGarage          Boolean  @default(false)
  hasGarden          Boolean  @default(false)
  hasBalcony         Boolean  @default(false)
  hasElevator        Boolean  @default(false)
  hasParkingSpace    Boolean  @default(false)
  hasCellar          Boolean  @default(false)
  hasTerrace         Boolean  @default(false)
  hasPool            Boolean  @default(false)
  hasAirConditioning Boolean  @default(false)
  isFurnished        Boolean  @default(false)
  hasConcierge       Boolean  @default(false)
  hasAlarm           Boolean  @default(false)
  energyClass        String?
  yearBuilt          Int?
  condominiumFees    Int?
  extraCosts         String?  @db.Text
  condition          String?
  heatingType        String?
  address       String
  city          String
  province      String
  cap           String
  lat           Float
  lng           Float
  zone          Zone?          @relation("PropertyZone", fields: [zoneId], references: [id])
  zoneId        String?
  photos        PropertyPhoto[]
  seller        User           @relation(fields: [sellerId], references: [id])
  sellerId      String
  assignment    PropertyAssignment?
  contract      Contract?
  visits        Visit[]
  leads         BuyerLead[]
  documents     Document[]
  favorites     Favorite[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  publishedAt   DateTime?
  viewCount     Int            @default(0)

  @@index([city, status])
  @@index([status])
  @@index([sellerId])
  @@index([zoneId])
}

enum PropertyType {
  APPARTAMENTO
  VILLA
  CASA_INDIPENDENTE
  ATTICO
  MANSARDA
  LOFT
  TERRENO
  NEGOZIO
  UFFICIO
}

enum PropertyStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  UNDER_CONTRACT
  SOLD
  WITHDRAWN
}

model PropertyPhoto {
  id         String   @id @default(cuid())
  url        String
  order      Int      @default(0)
  isCover    Boolean  @default(false)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
}

model PropertyAssignment {
  id         String           @id @default(cuid())
  property   Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String           @unique
  agency     Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyId   String
  assignedAt DateTime         @default(now())
  status     AssignmentStatus @default(ACTIVE)
  notes      String?          @db.Text

  @@index([agencyId])
  @@index([status])
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Contract {
  id           String   @id @default(cuid())
  property     Property @relation(fields: [propertyId], references: [id])
  propertyId   String   @unique
  type         String   @default("ESCLUSIVA_90_GIORNI")
  duration     Int      @default(90)
  signedAt     DateTime?
  expiresAt    DateTime?
  sellerSigned Boolean  @default(false)
  agencySigned Boolean  @default(false)
  documentUrl  String?
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}

model Visit {
  id          String      @id @default(cuid())
  property    Property    @relation(fields: [propertyId], references: [id])
  propertyId  String
  buyerName   String
  buyerEmail  String
  buyerPhone  String
  scheduledAt DateTime
  status      VisitStatus @default(PENDING)
  notes       String?     @db.Text
  createdAt   DateTime    @default(now())

  @@index([propertyId])
  @@index([status])
}

enum VisitStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model BuyerLead {
  id         String   @id @default(cuid())
  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String
  name       String
  email      String
  phone      String?
  message    String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([propertyId])
  @@index([email])
}

model SellerLead {
  id             String        @id @default(cuid())
  name           String
  email          String
  phone          String
  city           String
  province       String
  propertyType   PropertyType?
  estimatedValue Int?
  source         String?
  status         LeadStatus    @default(NEW)
  createdAt      DateTime      @default(now())

  @@index([status])
  @@index([email])
}

enum LeadStatus {
  NEW
  CONTACTED
  ONBOARDING
  APPROVED
  CONVERTED
  LOST
}

model AgencyLead {
  id              String     @id @default(cuid())
  agencyName      String
  contactName     String
  email           String
  phone           String
  address         String?
  city            String
  province        String
  agentCount      Int?
  message         String?    @db.Text
  preferredZones  Json?
  status          LeadStatus @default(NEW)
  approvalToken   String?
  approvedAt      DateTime?
  createdAt       DateTime   @default(now())
}

model Message {
  id         String   @id @default(cuid())
  content    String   @db.Text
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  senderId   String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  receiverId String
  propertyId String
  createdAt  DateTime @default(now())
  read       Boolean  @default(false)

  @@index([propertyId, createdAt])
  @@index([receiverId, read])
}

model Document {
  id         String   @id @default(cuid())
  name       String
  url        String
  size       Int
  mimeType   String
  category   String   @default("ALTRO")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  uploader   User     @relation("UploadedDocuments", fields: [uploaderId], references: [id])
  uploaderId String
  createdAt  DateTime @default(now())

  @@index([propertyId])
}

model Favorite {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
}

model SavedSearch {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  name       String
  filters    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?  @db.Text
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyId  String
  createdAt DateTime @default(now())

  @@unique([userId, agencyId])
  @@index([agencyId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Zone {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  zoneClass      ZoneClass
  region         String
  province       String
  city           String?
  capCodes       String[]
  municipalities String[]

  // Dati di mercato (ISTAT/OMI/NTN)
  population     Int        @default(0)
  ntn            Float      @default(0)
  marketScore    Int        @default(1)

  // Prezzi mensili per piano (centesimi). null = non disponibile
  priceBase      Int?
  priceLocal     Int?
  priceCity      Int?
  pricePrime     Int?
  priceElite     Int?

  // Limiti partner per piano. 0 = non disponibile
  maxBase        Int        @default(0)
  maxLocal       Int        @default(0)
  maxCity        Int        @default(0)
  maxPrime       Int        @default(0)
  maxElite       Int        @default(0)

  lat            Float?
  lng            Float?

  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  territories    TerritoryAssignment[]
  properties     Property[] @relation("PropertyZone")

  @@index([province])
  @@index([region])
  @@index([zoneClass])
}

model TerritoryAssignment {
  id           String     @id @default(cuid())
  agency       Agency     @relation(fields: [agencyId], references: [id])
  agencyId     String
  zone         Zone       @relation(fields: [zoneId], references: [id])
  zoneId       String
  plan         AgencyPlan
  monthlyPrice Int
  isActive     Boolean    @default(true)
  stripeItemId String?
  createdAt    DateTime   @default(now())

  @@unique([agencyId, zoneId])
  @@index([zoneId, isActive])
  @@index([agencyId, isActive])
}

model Complaint {
  id              String          @id @default(cuid())
  referenceNumber String          @unique
  name            String
  email           String
  userType        String          // "venditore" | "agenzia" | "acquirente"
  subject         String
  description     String          @db.Text
  status          ComplaintStatus @default(RECEIVED)
  createdAt       DateTime        @default(now())
  resolvedAt      DateTime?

  @@index([status])
  @@index([email])
}

enum ComplaintStatus {
  RECEIVED
  IN_REVIEW
  RESOLVED
  CLOSED
}
